{
  "name": "oxford-frontier-ai-forum-2026",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Landing site for the Oxford Frontier AI Forum 2026.",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsc --noEmit && vite build",
